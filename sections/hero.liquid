{{ 'section-hero.css' | asset_url | stylesheet_tag }}


<div>
  hero.liquid
</div>

{% schema %}
{
  "name": "t:sections.hero.name",
  "tag": "section",
  "class": "section hero",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero.settings.heading.label",
      "default": "Hero"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.hero.settings.description.label",
      "default": "<p>Hero description</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.hero.settings.image.label"
    }
  ],  
  "presets": [
    {
      "name": "t:sections.hero.presets.name"
    }
  ]
}
{% endschema %}


