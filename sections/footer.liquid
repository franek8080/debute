<footer class="footer" id="Footer-{{ section.id }}">

  <div class="footer__main container container--no-padding grid grid--4 grid--mb-1">

    <div class="footer__column footer__column--1" data-footer-column="1">
      {% if section.blocks.size > 0 %}
        {%- for block in section.blocks -%}
          {%- assign block_column = block.settings.position_column | default: 1 -%}
          {%- if block_column == 1 -%}
            {%- case block.type -%}
              {%- when 'link_list' -%}
                <div class="footer__block footer__block--accordion footer__block--{{ block.type }}">
                  <details data-accordion data-accordion-destroy="(min-width: 701px)" class="accordion">
                    <summary class="footer__block-summary accordion__summary">
                      <h4 class="footer__block-title footer__block-title--accordion accordion__summery-title">{{ block.settings.heading }}</h4>
                      {{- 'icon-arrow-right.svg' | inline_asset_content -}}
                    </summary>
                    <div class="footer__block-content accordion__content" data-content>
                      <div class="accordion__content-inner">
                        <ul class="footer__block-menu list-unstyled">
                          {%- for link in block.settings.menu.links -%}
                            <li class="footer__block-menu-item">
                              <a class="footer__block-menu-link" href="{{ link.url }}">{{ link.title }}</a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    </div>
                  </details>
                </div>
              {%- when 'social_media' -%}
                <div
                  class="footer__block footer__block--{{ block.type }}"
                  data-footer-social
                  data-origin-column="{{ block_column }}">
                  <h4 class="footer__block-title">{{ block.settings.heading }}</h4>
                  {%- render 'social-icons', class: 'footer__block-social-icons' -%}
                </div>
            {%- endcase -%}
          {%- endif -%}
        {%- endfor -%}
      {% endif %}
    </div>

    <div class="footer__column footer__column--2" data-footer-column="2">
      {% if section.blocks.size > 0 %}
        {%- for block in section.blocks -%}
          {%- assign block_column = block.settings.position_column | default: 1 -%}
          {%- if block_column == 2 -%}
            {%- case block.type -%}
              {%- when 'link_list' -%}
                <div class="footer__block footer__block--accordion footer__block--{{ block.type }}">
                  <details data-accordion data-accordion-destroy="(min-width: 701px)" class="accordion">
                    <summary class="footer__block-summary accordion__summary">
                      <h4 class="footer__block-title footer__block-title--accordion accordion__summery-title">{{ block.settings.heading }}</h4>
                      {{- 'icon-arrow-right.svg' | inline_asset_content -}}
                    </summary>
                    <div class="footer__block-content accordion__content" data-content>
                      <div class="accordion__content-inner">
                        <ul class="footer__block-menu list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li class="footer__block-menu-item">
                            <a class="footer__block-menu-link" href="{{ link.url }}">{{ link.title }}</a>
                          </li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    </div>
                  </details>
                </div>
              {%- when 'social_media' -%}
                <div
                  class="footer__block footer__block--{{ block.type }}"
                  data-footer-social
                  data-origin-column="{{ block_column }}">
                  <h4 class="footer__block-title">{{ block.settings.heading }}</h4>
                  {%- render 'social-icons', class: 'footer__block-social-icons' -%}
                </div>
            {%- endcase -%}
          {%- endif -%}
        {%- endfor -%}
      {% endif %}
    </div>

    <div class="footer__column footer__column--3" data-footer-column="3">
      {% if section.blocks.size > 0 %}
        {%- for block in section.blocks -%}
          {%- assign block_column = block.settings.position_column | default: 1 -%}
          {%- if block_column == 3 -%}
            {%- case block.type -%}
              {%- when 'link_list' -%}
                <div class="footer__block footer__block--accordion footer__block--{{ block.type }}">
                  <details data-accordion data-accordion-destroy="(min-width: 701px)" class="accordion">
                    <summary class="footer__block-summary accordion__summary">
                      <h4 class="footer__block-title footer__block-title--accordion accordion__summery-title">{{ block.settings.heading }}</h4>
                      {{- 'icon-arrow-right.svg' | inline_asset_content -}}
                    </summary>
                    <div class="footer__block-content accordion__content" data-content>
                      <div class="accordion__content-inner">
                        <ul class="footer__block-menu list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li class="footer__block-menu-item">
                            <a class="footer__block-menu-link" href="{{ link.url }}">{{ link.title }}</a>
                          </li>
                        {%- endfor -%}
                        </ul>
                      </div>
                    </div>
                  </details>
                </div>
              {%- when 'social_media' -%}
                <div
                  class="footer__block footer__block--{{ block.type }}"
                  data-footer-social
                  data-origin-column="{{ block_column }}">
                  <h4 class="footer__block-title">{{ block.settings.heading }}</h4>
                  {%- render 'social-icons', class: 'footer__block-social-icons' -%}
                </div>
            {%- endcase -%}
          {%- endif -%}
        {%- endfor -%}
      {% endif %}
    </div>

    <div class="footer__column footer__column--text" data-footer-column="4">
      {% if section.blocks.size > 0 %}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'text' -%}
              <div class="footer__block footer__block--{{ block.type }}">
                <h4 class="footer__block-title">{{ block.settings.heading }}</h4>
                <div class="footer__block-text">{{ block.settings.subtext }}</div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      {% endif %}

      <div
        class="footer__block footer__block--copyrights"
        data-footer-copyright>
  
        <figure class="header__logo">
          {{- 'icon-logo.svg' | inline_asset_content -}}
        </figure>

        <p class="footer__copyrights">
          ©All rights reserved 1991<br>
          Warszawa {{ 'now' | date: '%Y' }}
        </p>
  
        <p class="footer__authors">
          Designed with love by <a href="https://we3studio.pl" target="_blank">we3studio</a><br>
          Coded by <a href="https://8080.studio" target="_blank">8080</a>
        </p>
  
      </div>

    </div>

  </div>

  <div class="footer__policies container">

    <ul class="footer__policies-menu list-unstyled">
      {%- for policy in shop.policies -%}
        {%- if policy != blank -%}
          <li class="footer__policy-item">
            <a class="footer__policy-link" href="{{ policy.url }}">{{ policy.title | escape }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>

</footer>

<script>
  (() => {
    const footer = document.getElementById('Footer-{{ section.id }}');
    if (!footer) return;

    const mobileMedia = window.matchMedia('(max-width: 700px)');

    const syncFooterSocialColumn = () => {
      const isMobile = mobileMedia.matches;
      const targetColumn = footer.querySelector('[data-footer-column="4"]');
      const targetAnchor = footer.querySelector('[data-footer-copyright]');
      const socialBlocks = footer.querySelectorAll('[data-footer-social]');

      socialBlocks.forEach((block) => {
        const originColumn = block.dataset.originColumn || '3';
        const originColumnEl = footer.querySelector(`[data-footer-column="${originColumn}"]`);

        if (isMobile) {
          if (targetColumn && block.parentElement !== targetColumn) {
            if (targetAnchor) {
              targetColumn.insertBefore(block, targetAnchor);
            } else {
              targetColumn.appendChild(block);
            }
          }
          return;
        }

        if (originColumnEl && block.parentElement !== originColumnEl) {
          originColumnEl.appendChild(block);
        }
      });
    };

    window.addEventListener('resize', syncFooterSocialColumn);
    document.addEventListener('shopify:section:load', syncFooterSocialColumn);
    syncFooterSocialColumn();
  })();
</script>



{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        },
        {
          "type": "range",
          "id": "position_column",
          "min": 1,
          "max": 3,
          "step": 1,
          "label": "t:sections.footer.blocks.link_list.settings.position_column.label",
          "default": 1
        }
      ]
    },
    {
      "type": "social_media",
      "name": "t:sections.footer.blocks.social_media.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.social_media.settings.heading.label",
          "default": "Social media"
        },
        {
          "type": "range",
          "id": "position_column",
          "min": 1,
          "max": 3,
          "step": 1,
          "label": "t:sections.footer.blocks.social_media.settings.position_column.label",
          "default": 3
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "t:sections.footer.blocks.text.settings.heading.default",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "t:sections.footer.blocks.text.settings.subtext.default",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        }
      ]
    }
  ],
  "settings": [

  ],
  "default": {
    "blocks": [
      {
        "type": "link_list"
      },
      {
        "type": "text"
      }
    ]
  }
}
{% endschema %}
